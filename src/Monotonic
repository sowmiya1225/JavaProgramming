package phasethree;

public class DataStructuresDemo {

    public static void main(String[] args) {

        MonotonicI mi = new MonotonicI();
        MonotonicD md = new MonotonicD();

        int[] nums = {4, 1, 3, 4, 2};

        for (int num : nums) {
            mi.push(num);
            md.push(num);
        }

        mi.print();
        md.print();
    }
}

class MyLL {

    Node head = null;

    class Node {
        int data;
        Node next = null;

        Node(int data) {
            this.data = data;
        }
    }

    void insertAtEnd(int data) {
        Node nn = new Node(data);

        if (head == null) {
            head = nn;
        } else {
            Node temp = head;
            while (temp.next != null) {
                temp = temp.next;
            }
            temp.next = nn;
        }
    }

    void insertAtFront(int data) {
        Node nn = new Node(data);
        nn.next = head;
        head = nn;
    }

    void insertAtPosition(int data, int pos) {
        if (pos == 1) {
            insertAtFront(data);
        } else {
            Node nn = new Node(data);
            Node temp = head;
            for (int i = 1; i <= pos - 2; i++) {
                temp = temp.next;
            }
            nn.next = temp.next;
            temp.next = nn;
        }
    }

    int deleteAtEnd() {
        if (head == null) {
            return -1;
        } else {
            Node temp = head;
            while (temp.next != null && temp.next.next != null) {
                temp = temp.next;
            }
            int deletedValue = temp.next.data;
            temp.next = null;
            return deletedValue;
        }
    }

    int deleteAtFront() {
        if (head == null) {
            return -1;
        } else {
            int deleted = head.data;
            head = head.next;
            return deleted;
        }
    }

    int deleteAtPosition(int pos) {

        if (pos <= 0) {
            System.out.println("Invalid position");
            return -1;
        }

        if (pos == 1)
            return deleteAtFront();

        Node temp = head;

        for (int i = 1; i <= pos - 2 && temp != null; i++) {
            temp = temp.next;
        }

        if (temp == null) {
            System.out.println("Given Position exceeds the length of the LL");
            return -1;
        }

        int deleted = temp.next.data;
        temp.next = temp.next.next;

        return deleted;
    }

    void reverse() {

        Node temp = head;
        Node left = null;
        Node right = null;

        while (temp != null) {
            right = temp.next;
            temp.next = left;
            left = temp;
            temp = right;
        }

        head = left;
    }

    void recursiveReverse() {
        head = helper(head);
    }

    Node helper(Node node) {

        if (node == null || node.next == null) {
            return node;
        }

        Node newHead = helper(node.next);

        node.next.next = node;
        node.next = null;

        return newHead;
    }

    public void print() {

        Node temp = head;

        if (head == null) {
            System.out.println("LinkedList is NULL");
            return;
        }

        while (temp.next != null) {
            System.out.print(temp.data + " -> ");
            temp = temp.next;
        }

        System.out.println(temp.data);
    }
}

class MyStack extends MyLL {

    void push(int data) {
        insertAtFront(data);
    }

    int pop() {
        return deleteAtFront();
    }

    int peek() {
        return super.head.data;
    }

    boolean isEmpty() {
        return this.head == null;
    }

    public void print() {

        helperPrint(this.head);
        System.out.println();
    }

    void helperPrint(Node n) {

        if (n == null)
            return;

        helperPrint(n.next);

        System.out.print(n.data + " | ");
    }
}

class MyQueue extends MyLL {

    void enqueue(int data) {
        insertAtEnd(data);
    }

    int dequeue() {
        return deleteAtFront();
    }

    int peek() {
        return super.head.data;
    }

    boolean isEmpty() {
        return super.head == null;
    }
}

class MonotonicI extends MyStack {

    void push(int data) {

        while (!super.isEmpty() && super.peek() > data) {
            super.pop();
        }

        super.push(data);
    }
}

class MonotonicD extends MyStack {

    void push(int data) {

        while (!super.isEmpty() && super.peek() <= data) {
            super.pop();
        }

        super.push(data);
    }
}
