package phasethree;
import java.util.Scanner;
public class Withoutusingloop {
	public static void main(String[]args) {
		Scanner s=new Scanner(System.in);
		int n=s.nextInt();
		System.out.println("Sum of odd numbers"+ n*n);
		System.out.println("Sum of first n even numbers"+(n*n-1));	
		System.out.println("Sum of first n even numbers"+(n*n+1));
		}
}
