package phasethree;
import java.util.Arrays;
public class SlidingWindow {
	public static void main(String[]args) {
		int[]nums= {1,3,-1,-3,5,3,6,7};
		int k=3;
		System.out.println(Arrays.toString(nums));
		for(int i=0;i<=nums.length-k;i++) {
			for(int j=i;j<i+k;j++) {
				System.out.println();
			}
		}
	}
}
